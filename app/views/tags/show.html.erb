<div class="container">
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-7">
      <h1><%= @tag.name %></h1>
      <p class="text-secondary">
        <%= @tag.description unless @tag.description.nil? %>
      </p>
    </div>
  </div>
  <% @movie_schedules.each do |date, cine| %>
    <div class="row mt-5">
      <div class="col-md-1 sticky-top align-self-start" style="top: 70px; z-index: 1031;">
        <div class="p-2 bg-primary-subtle text-black text-center rounded">
          <b><%= date %></b>
        </div>
      </div>
      <div class="col-md-11">

        <% cine.each do |cinema, v| %>
          <div class="row">
            <div class="col-md-12">
              <div class="p-2 mb-3 bg-body-secondary text-black rounded">
                <b><%= cinema %></b>
              </div>
            </div>

            <% v.each do |value| %>

              <div class="col-md-4">
                <div>
                  <%= image_tag("https://image.tmdb.org/t/p/w500" + value.movie.poster_path, width: "60", class: "float-start me-3") unless value.movie.poster_path.nil? %>
                </div>
                <div>
                  <%= link_to value.movie.title, "/movies/" + value.movie.id.to_s %>
                </div>
                <div>
                  <span class="text-black">
                    <%= value.time.in_time_zone("Vienna").strftime("%H:%M") %>
                  </span>
                  <span class="text-secondary small">
                    <%= value.info %>
                  </span>
                </div>
                <div>
                  <span class="text-secondary small">
                    <%= value.movie.countries %> <%= value.movie.year %> <%= value.movie.director %>
                  </span>
                </div>
                <div>
                  <span class="text-black">
                    <%= truncate_and_link(value.movie.description, length: 170, url: "/movies/" + value.movie.id.to_s) %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

